# Prevent caching of all HTML responses (covers SPA routes rewritten to index.html)
<FilesMatch "\.html$">
  Header always set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
  Header always set Pragma "no-cache"
  Header always set Expires "0"
</FilesMatch>

# Long-term cache for hashed assets (JS/CSS with content hash in filename)
<FilesMatch "\.(js|css|woff2?|ttf|eot|svg|png|jpg|jpeg|gif|ico|webp)$">
  Header always set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>
